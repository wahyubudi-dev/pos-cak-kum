# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
# Get these from your Supabase project: Settings → API
#   - URL: Project URL
#   - ANON_KEY: Public anon (client-safe) key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key. Used for admin operations (e.g. creating the first admin
# user, server-side mutations that bypass RLS). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------------------
# Drizzle / Postgres
# ----------------------------------------------------------------------------
# Connection string used by Drizzle ORM and Drizzle Kit (db:* scripts).
#
# IMPORTANT: Use the Transaction Pooler endpoint (port 6543), NOT the direct
# connection (port 5432). Get this from Supabase: Settings → Database →
# Connection string → Transaction. Replace [YOUR-PASSWORD] with the database
# password you set when creating the project.
#
# Example shape (regional pooler):
#   postgres://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres.your-project-ref:your-db-password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# Base URL used for OAuth callbacks. Localhost in dev, your real domain in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ----------------------------------------------------------------------------
# Xendit Payment Gateway
# ----------------------------------------------------------------------------
# Sandbox: get your API key from https://dashboard.xendit.co/settings/api-keys
# Starts with "xnd_development_"
XENDIT_API_KEY=xnd_development_your-sandbox-api-key

# Webhook verification token. Set this in Xendit dashboard → Settings → Webhooks.
# Leave empty during development to skip verification.
XENDIT_WEBHOOK_TOKEN=

# Master admin email — user with this email cannot be downgraded from admin.
MASTER_ADMIN_EMAIL=
